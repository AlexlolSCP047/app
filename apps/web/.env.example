# Copia este archivo a .env y rellena los valores reales. NUNCA subas .env a git.

# Base de datos PostgreSQL (crea una gratis en https://neon.tech y pega aquí su URL)
DATABASE_URL="postgresql://usuario:contrasena@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Secreto para firmar las sesiones (genera uno con: openssl rand -hex 32)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL pública de la web (para redirecciones de Stripe)
APP_URL="http://localhost:3000"

# ------ IA del entrenador ------
# Proveedor: "cerebras" (gratis) o "claude". Si no se indica, usa Cerebras
# automáticamente cuando hay CEREBRAS_API_KEY; si no, Claude.
# AI_PROVIDER="cerebras"

# Cerebras (gratis) — https://cloud.cerebras.ai
CEREBRAS_API_KEY="csk-..."
# Modelo (opcional). Por defecto: gemma-4-31b
# CEREBRAS_MODEL="gemma-4-31b"

# Claude (Anthropic) — https://platform.claude.com (solo si usas AI_PROVIDER=claude)
# ANTHROPIC_API_KEY="sk-ant-..."
# CLAUDE_MODEL="claude-opus-4-8"

# Stripe (pagos) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Precio recurrente mensual de 9,99 EUR creado en Stripe (Products > Price)
STRIPE_PRICE_ID="price_..."
# Secreto del webhook (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET="whsec_..."

