// Esquema de base de datos (PostgreSQL — compatible con Neon/Vercel).
// Usa la misma DATABASE_URL de Neon tanto en local como en producción.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  phone              String? // opcional: solo para recordatorios, no obligatorio en el registro
  passwordHash       String
  createdAt          DateTime  @default(now())

  // Campo heredado (la prueba ahora la gestiona Stripe con trial de 7 días)
  trialEndsAt        DateTime

  // Facturación (Stripe)
  stripeCustomerId   String?   @unique
  subscriptionId     String?
  subscriptionStatus String    @default("none") // none | trialing | active | past_due | canceled
  currentPeriodEnd   DateTime?

  profile      TrainingProfile?
  plans        TrainingPlan[]
  messages     ChatMessage[]
  workouts     WorkoutLog[]
  progress     ProgressEntry[]
  resetTokens  PasswordResetToken[]
}

// Token de un solo uso para "olvidé mi contraseña". Se guarda solo el hash
// SHA-256 del token: el valor real viaja únicamente en el enlace del correo.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model TrainingProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        String // p. ej. "perder grasa", "ganar músculo", "resistencia"
  level       String // principiante | intermedio | avanzado
  daysPerWeek Int
  equipment   String // "gimnasio completo", "mancuernas en casa", "sin material"…
  injuries    String? // lesiones o limitaciones
  age         Int?
  weightKg    Float?
  heightCm    Float?
  // Datos del onboarding ampliado
  sex         String? // hombre | mujer | otro
  focusAreas  String? // zonas prioritarias, separadas por comas
  sessionMins Int? // duración objetivo por sesión
  updatedAt   DateTime @updatedAt
}

model TrainingPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planJson  String // plan semanal completo en JSON generado por la IA
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
}

// Sesión completada: alimenta el calendario, la racha y la IA adaptativa.
model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayLabel    String // "Día 1 - Lunes"
  focus       String? // grupo muscular o tipo de sesión
  difficulty  String // facil | justo | dificil (percepción del esfuerzo)
  notes       String?
  completedAt DateTime @default(now())

  @@index([userId, completedAt])
}

// Registro de progreso (peso corporal o marca en un ejercicio).
model ProgressEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // peso_corporal | ejercicio
  label     String // "Peso corporal" o el nombre del ejercicio
  value     Float // kg (peso) o carga levantada
  reps      Int? // repeticiones (solo para ejercicios)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
